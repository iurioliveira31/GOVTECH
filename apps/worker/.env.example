# ──────────────────────────────────────────────────────────────────────────────
# worker — Template de variáveis de ambiente
# Copie para .env e preencha com valores reais. NUNCA versionar o .env!
# ──────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# ── Redis (BullMQ) ────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── PNCP API ──────────────────────────────────────────────────────────────────
PNCP_BASE_URL="https://pncp.gov.br/api/consulta"
PNCP_PAGE_SIZE=500
PNCP_REQUEST_DELAY_MS=300
PNCP_MAX_RETRIES=3

# ── BullMQ Worker ─────────────────────────────────────────────────────────────
PNCP_WORKER_CONCURRENCY=2
PNCP_WORKER_RATE_MAX=5
PNCP_WORKER_RATE_DURATION=1000

# ── Agendamento de sync ───────────────────────────────────────────────────────
# Cron: a cada 2h por padrão. Formato: minuto hora dia mês dia-semana
PNCP_SYNC_CRON="0 */2 * * *"
# Se true, dispara sync imediato ao inicializar o worker
PNCP_SYNC_ON_START=false

# ── Observabilidade ───────────────────────────────────────────────────────────
METRICS_PORT=9090
NODE_ENV=development
LOG_LEVEL=info
