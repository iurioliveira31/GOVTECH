# ──────────────────────────────────────────────────────────────────────────────
# api-gateway — Template de variáveis de ambiente
# Copie para .env e preencha com valores reais. NUNCA versionar o .env!
# ──────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT — use secrets criptograficamente aleatórios em produção ───────────────
# Gerar: openssl rand -base64 64
JWT_SECRET="REPLACE_WITH_RANDOM_SECRET_MIN_64_CHARS"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_RANDOM_SECRET_MIN_64_CHARS"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Observabilidade ───────────────────────────────────────────────────────────
SENTRY_DSN=""
LOG_LEVEL=info
